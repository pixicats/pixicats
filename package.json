{
  "name": "pixicats-web3-pvp",
  "version": "0.5.0",
  "private": true,
  "description": "PixiCats React/Vite Web3 PvP economy game on Base",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "compile:contracts": "hardhat compile",
    "deploy:base": "hardhat run scripts/deploy.ts --network base"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ethers": "latest",
    "@openzeppelin/contracts": "latest",
    "@vitejs/plugin-react": "latest",
    "dotenv": "latest",
    "ethers": "latest",
    "hardhat": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "type": "module"
}
